{
  "name": "app",
  "scripts": {
    "dev": "run-s build:turingcanvas dev:parallel",
    "dev:parallel": "run-p dev:turingcanvas dev:frontend",
    "dev:turingcanvas": "npm run dev --workspace=turingcanvas",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "run-s build:turingcanvas build:frontend",
    "build:turingcanvas": "npm run build --workspace=turingcanvas",
    "build:frontend": "npm run build --workspace=frontend"
  },
  "workspaces": ["frontend", "turingcanvas"],
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
