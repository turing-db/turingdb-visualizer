{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "ESNext.Iterator"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "jsx": "react-jsx",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@assets/*": ["./src/assets/*"],
      "@turingcanvas": ["./src/turingcanvas/src/index.ts"]
    }
  },
  "include": [
    "node_modules/vite/client.d.ts",
    "src",
    "src/turingcanvas/src/types",
    "src/turingcanvas/src/troika-three-text.d.ts",
    "vite.config.ts"
  ],
  "exclude": ["src/turingcanvas/tsup.config.ts"]
}
